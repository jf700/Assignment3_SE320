@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container Diagram - Digital Therapy Assistant

Person(patient, "Patient", "Primary user seeking burnout recovery")
Person(therapist, "Therapist", "Monitors patient progress")
Person(aiUser, "AI Client User", "Uses Claude Desktop/Code via MCP")

System_Boundary(dta, "Digital Therapy Assistant") {
    Container(frontend, "Frontend Application", "Next.js, React 19, Nginx", "Single-page application served via Nginx on port 3000, proxies API requests to backend")
    Container(api, "Spring Boot Application", "Java 21, Spring Boot 4.0", "Provides REST API, business logic, security, and AI integration on port 8080")
    Container(mcp, "MCP Server", "Spring AI MCP, stdio", "Exposes therapy tools, resources, and prompts for AI clients via Model Context Protocol")
    ContainerDb(h2db, "H2 Database", "H2 (File-based)", "Stores users, sessions, diary entries, chat messages, and cognitive distortions")
    Container(vectorstore, "SimpleVector Store", "Java, In-Memory", "Vector storage for RAG similarity search using cosine similarity")
    Container(kb, "Knowledge Base", "JSON Files", "CBT reference materials: distortions, techniques, crisis protocols")
}

System_Ext(llm, "LLM Provider", "Anthropic Claude API")

Rel(patient, frontend, "Browses web application", "HTTPS / Port 3000")
Rel(therapist, api, "Monitors progress via", "HTTPS/JSON / Port 8080")
Rel(aiUser, mcp, "Connects via", "stdio / MCP Protocol")

Rel(frontend, api, "Proxies API requests via Nginx", "HTTP / Port 8080")
Rel(mcp, api, "Delegates to service layer", "Spring DI")
Rel(api, h2db, "Reads/writes data", "JPA/JDBC")
Rel(api, vectorstore, "Stores and queries embeddings", "Java API")
Rel(api, kb, "Loads CBT reference content", "File I/O")
Rel(vectorstore, kb, "Indexes content from", "Embeddings")
Rel(api, llm, "Sends prompts, receives responses", "HTTPS/REST")

@enduml
