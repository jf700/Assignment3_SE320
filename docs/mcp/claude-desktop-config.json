{
  "mcpServers": {
    "digital-therapy": {
      "command": "java",
      "args": [
        "-jar",
        "target/digitaltherapy-0.0.1-SNAPSHOT.jar",
        "--spring.profiles.active=mcp"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "<your-anthropic-api-key>",
        "JWT_SECRET": "<your-jwt-secret>"
      }
    }
  }
}
